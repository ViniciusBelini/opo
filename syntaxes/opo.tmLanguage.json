{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Opo",
  "scopeName": "source.opo",
  "fileTypes": [
    "opo"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#function-declarations"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.opo",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.opo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.opo",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.opo",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.opo",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.opo",
          "match": "\\b(pub|imp|match|go|try|catch|throw)\\b"
        },
        {
          "name": "keyword.declaration.opo",
          "match": "\\b(type|struct|enum|chan|as)\\b"
        },
        {
          "name": "keyword.control.flow.opo",
          "match": "(\\^|\\.\\.|\\.|\\?|:|@)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.opo",
          "match": "\\b(int|flt|bol|str|void|any)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.opo",
          "match": "\\b(tru|fls)\\b"
        },
        {
          "name": "constant.language.option.opo",
          "match": "\\b(some|none|ok|err)\\b"
        }
      ]
    },
    "function-declarations": {
      "patterns": [
        {
          "name": "meta.function.definition.opo",
          "match": "(?<=:)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\[)",
          "captures": {
            "1": {
              "name": "entity.name.function.opo"
            }
          }
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "meta.function.call.opo",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.opo"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.opo",
          "match": "(=>|->|<-|!!|==|!=|<=|>=|&&|\\|\\||\\+|-|\\*|/|%|=|<|>|!)"
        },
        {
          "name": "punctuation.separator.delimiter.opo",
          "match": "[\\[\\]{}(),.]"
        }
      ]
    }
  }
}
