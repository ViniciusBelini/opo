<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language SYSTEM "language.dtd">
<language
    name="Opo"
    version="1.0"
    kateversion="5.0"
    section="Sources"
    extensions="*.opo"
    mimetype="text/x-opo"
    license="MIT"
    author="OpenAI Codex">
  <highlighting>
    <list name="keywords">
      <item> pub </item>
      <item> imp </item>
      <item> type </item>
      <item> struct </item>
      <item> enum </item>
      <item> match </item>
      <item> go </item>
      <item> chan </item>
      <item> as </item>
      <item> try </item>
      <item> catch </item>
      <item> throw </item>
    </list>

    <list name="types">
      <item> int </item>
      <item> flt </item>
      <item> bol </item>
      <item> str </item>
      <item> void </item>
      <item> any </item>
    </list>

    <list name="constants">
      <item> tru </item>
      <item> fls </item>
      <item> some </item>
      <item> none </item>
      <item> ok </item>
      <item> err </item>
    </list>

    <list name="operators">
      <item> =&gt; </item>
      <item> -&gt; </item>
      <item> &lt;- </item>
      <item> !! </item>
      <item> == </item>
      <item> != </item>
      <item> &lt;= </item>
      <item> &gt;= </item>
      <item> &amp;&amp; </item>
      <item> || </item>
      <item> + </item>
      <item> - </item>
      <item> * </item>
      <item> / </item>
      <item> % </item>
      <item> = </item>
      <item> &lt; </item>
      <item> &gt; </item>
      <item> ! </item>
      <item> ? </item>
      <item> : </item>
      <item> @ </item>
      <item> .. </item>
      <item> . </item>
      <item> ^ </item>
    </list>

    <contexts>
      <context name="Normal" attribute="Normal Text" lineEndContext="#stay">
        <DetectChar attribute="Comment" context="Comment" char="#"/>

        <keyword attribute="Keyword" context="#stay" String="keywords"/>
        <keyword attribute="Data Type" context="#stay" String="types"/>
        <keyword attribute="Constant" context="#stay" String="constants"/>
        <keyword attribute="Operator" context="#stay" String="operators"/>

        <RegExpr attribute="Function" context="#stay" String="\b[A-Za-z_][A-Za-z0-9_]*(?=\s*\()" insensitive="false"/>
        <RegExpr attribute="Function" context="#stay" String="\b[A-Za-z_][A-Za-z0-9_]*(?=\s*\[)" insensitive="false"/>

        <Float attribute="Float" context="#stay"/>
        <Int attribute="Decimal" context="#stay"/>
        <DetectChar attribute="String" context="String" char="&quot;"/>

        <Detect2Chars attribute="Operator" context="#stay" char="=" char1="&gt;"/>
        <Detect2Chars attribute="Operator" context="#stay" char="-" char1="&gt;"/>
        <Detect2Chars attribute="Operator" context="#stay" char="&lt;" char1="-"/>
        <Detect2Chars attribute="Operator" context="#stay" char="!" char1="!"/>
        <Detect2Chars attribute="Operator" context="#stay" char="=" char1="="/>
        <Detect2Chars attribute="Operator" context="#stay" char="!" char1="="/>
        <Detect2Chars attribute="Operator" context="#stay" char="&lt;" char1="="/>
        <Detect2Chars attribute="Operator" context="#stay" char="&gt;" char1="="/>
        <Detect2Chars attribute="Operator" context="#stay" char="&amp;" char1="&amp;"/>
        <Detect2Chars attribute="Operator" context="#stay" char="|" char1="|"/>
        <Detect2Chars attribute="Operator" context="#stay" char="." char1="."/>

        <AnyChar attribute="Operator" context="#stay" String="+-*/%=&lt;&gt;!?:@.^"/>
        <AnyChar attribute="Symbol" context="#stay" String="[]{}(),"/>
      </context>

      <context name="Comment" attribute="Comment" lineEndContext="#pop"/>

      <context name="String" attribute="String" lineEndContext="#stay">
        <Detect2Chars attribute="Char" context="#stay" char="\" char1="\"/>
        <Detect2Chars attribute="Char" context="#stay" char="\" char1="n"/>
        <Detect2Chars attribute="Char" context="#stay" char="\" char1="t"/>
        <Detect2Chars attribute="Char" context="#stay" char="\" char1="r"/>
        <Detect2Chars attribute="Char" context="#stay" char="\" char1="&quot;"/>
        <Detect2Chars attribute="Char" context="#stay" char="\" char1="'"/>
        <DetectChar attribute="String" context="#pop" char="&quot;"/>
        <HlCChar attribute="Char" context="#stay"/>
      </context>
    </contexts>

    <itemDatas>
      <itemData name="Normal Text" defStyleNum="dsNormal"/>
      <itemData name="Keyword" defStyleNum="dsKeyword"/>
      <itemData name="Data Type" defStyleNum="dsDataType"/>
      <itemData name="Constant" defStyleNum="dsConstant"/>
      <itemData name="Operator" defStyleNum="dsOperator"/>
      <itemData name="Symbol" defStyleNum="dsNormal"/>
      <itemData name="Function" defStyleNum="dsFunction"/>
      <itemData name="Decimal" defStyleNum="dsDecVal"/>
      <itemData name="Float" defStyleNum="dsFloat"/>
      <itemData name="String" defStyleNum="dsString"/>
      <itemData name="Char" defStyleNum="dsChar"/>
      <itemData name="Comment" defStyleNum="dsComment"/>
    </itemDatas>
  </highlighting>

  <general>
    <comments>
      <comment name="singleLine" start="#"/>
    </comments>
  </general>
</language>
